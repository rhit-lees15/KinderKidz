import vlc
import time
import random


def init_vlc(sound_file:str):
    p = vlc.MediaPlayer(sound_file)
    p.play()
    time.sleep(1) #this is necessary because is_playing() returns false if called right away
    while p.is_playing():
        time.sleep(1)
    p.release()

